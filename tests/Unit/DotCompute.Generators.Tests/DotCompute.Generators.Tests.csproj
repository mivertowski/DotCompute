<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <WarningsNotAsErrors />
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <!-- Test packages are included from Directory.Build.targets -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Runtime\DotCompute.Generators\DotCompute.Generators.csproj" />
    <ProjectReference Include="..\..\..\tests\Shared\DotCompute.Tests.Common\DotCompute.Tests.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Use $(Configuration), not a hardcoded Debug path: a Release CI build produces the
         generator under bin/Release, so the old Debug path failed with CS0006 (it only
         worked locally when a stale Debug DLL happened to exist). -->
    <Analyzer Include="..\..\..\src\Runtime\DotCompute.Generators\bin\$(Configuration)\netstandard2.0\DotCompute.Generators.dll" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="TestData\**\*.cs" />
  </ItemGroup>

</Project>