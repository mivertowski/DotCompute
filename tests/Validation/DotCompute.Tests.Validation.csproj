<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Required so transitive test-framework assemblies (xunit.core, Moq, Castle.Core,
         FluentAssertions, Microsoft.NET.Test.Sdk) are copied to the output directory;
         without this the test host fails to load Castle.Core at runtime. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <!-- No explicit package references - managed by Directory.Build.props -->

  <ItemGroup>
    <ProjectReference Include="../../src/Core/DotCompute.Abstractions/DotCompute.Abstractions.csproj" />
    <ProjectReference Include="../../src/Core/DotCompute.Core/DotCompute.Core.csproj" />
    <ProjectReference Include="../../src/Backends/DotCompute.Backends.CUDA/DotCompute.Backends.CUDA.csproj" />
    <ProjectReference Include="../../src/Runtime/DotCompute.Runtime/DotCompute.Runtime.csproj" />
    <ProjectReference Include="../Shared/DotCompute.Tests.Common/DotCompute.Tests.Common.csproj" />
  </ItemGroup>

</Project>